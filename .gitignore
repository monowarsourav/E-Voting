# .gitignore

# Compiled binaries (actual go build output names)
/api-server
/aggregator-a
/aggregator-b
/cli
/covertvote-api
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build outputs
/build/
/dist/
/bin/

# Test binary
*.test

# Output
*.out
coverage.out
coverage.html

# Go workspace
go.work

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.local

# Database
*.db
*.db-shm
*.db-wal
data/

# Logs
logs/
*.log

# Build
dist/
build/

# Temporary
tmp/
temp/

# OS
.DS_Store
Thumbs.db

# Keys and secrets
*.pem
*.key
*.crt
keys/

# Fabric credentials
wallet/
connection-profile.json

# Go vendor (using modules)
vendor/

# Binary output directory
bin/
caliper/node_modules/
node_modules/

# Compiled binaries (tracked by accident — untrack with `git rm --cached -r bin/`)
bin/
build/

# Fabric crypto material — NEVER commit private keys
# To purge from history: `git filter-branch --force --index-filter \
#   "git rm -r --cached --ignore-unmatch network/crypto-config/" --prune-empty -- --all`
network/crypto-config/
network/channel-artifacts/

# Secrets
.env
.env.local
.env.*.local

# Data files
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# TLS certificates
certs/
*.pem
*.key
*.crt
