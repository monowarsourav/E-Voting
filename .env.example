# .env.example
# Copy this to .env and fill in the values

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=debug

# Database
DATABASE_PATH=./data/covertvote.db

# Security
ADMIN_TOKEN=your-admin-token-here-change-this
JWT_SECRET=your-jwt-secret-here-change-this

# SA² Servers
SA2_SERVER_A_URL=http://localhost:8081
SA2_SERVER_B_URL=http://localhost:8082

# Hyperledger Fabric
FABRIC_NETWORK=test
FABRIC_CHANNEL=covertvote-channel
FABRIC_CHAINCODE=covertvote-chaincode
FABRIC_ENABLED=false

# Crypto
PAILLIER_KEY_SIZE=2048
PEDERSEN_KEY_SIZE=512
RING_KEY_SIZE=512
SMDC_SLOTS=5

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
